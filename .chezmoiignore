# secrets (defense-in-depth; we never `chezmoi add` these anyway)
.credentials.json
**/.credentials.json
*.bak
*.backup-*

# per-machine sync config (Telegram token + role) — never synced
.config/claude-sync

# macOS-only scheduler (would clutter Linux) — keep machine-local
Library/LaunchAgents

# regenerable skill artifacts — sync source, not built output
.claude/skills/**/.venv
.claude/skills/**/node_modules
.claude/skills/**/__pycache__
.claude/skills/**/*.pyc

# externally-managed symlinked skills (would dangle on other machines)
.claude/skills/cua-driver
.claude/skills/defuddle
.claude/skills/json-canvas
.claude/skills/obsidian-bases
.claude/skills/obsidian-cli
.claude/skills/obsidian-markdown
.claude/skills/postiz
.claude/skills/skill-creator
.claude/skills/supabase-postgres-best-practices

# VPS (Linux) keeps its own settings.json; statusline.sh is now cross-platform
# and shared (Mac authoritative). context-mode 3rd line no-ops where unavailable.
{{ if eq .chezmoi.os "linux" -}}
.claude/settings.json
{{ end -}}

# GSD (@opengsd/gsd-core) agents — externally-managed, regenerable via
# `npx @opengsd/gsd-core --claude --global` and `gsd update`. Like the GSD
# skills/hooks/runtime (already unmanaged), GSD owns these; chezmoi must not
# revert them on apply. settings.json GSD hooks stay managed (templated) because
# that file is chezmoi-owned as a whole.
.claude/agents/gsd-*.md
